{
  "name": "moniezi-core",
  "private": true,
  "version": "30.4.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "check": "npm run typecheck && npm run lint && npm run test:regression",
    "test:regression": "rm -rf .tmp/regression-tests && tsc -p tsconfig.regression.json && node .tmp/regression-tests/tests/regression/runAll.js"
  },
  "dependencies": {
    "@pdf-lib/fontkit": "^1.1.1",
    "html2pdf.js": "^0.10.1",
    "lucide-react": "^0.462.0",
    "pdf-lib": "^1.17.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.6.3",
    "vite": "^6.0.5",
    "eslint": "^9.18.0",
    "@eslint/js": "^9.18.0",
    "globals": "^15.14.0",
    "typescript-eslint": "^8.21.0"
  }
}
